# Public branding
NEXT_PUBLIC_SITE_NAME=TAPEKETAN WiFi
NEXT_PUBLIC_SITE_SUBTITLE=Voucher internet cepat, bayar QRIS, kode muncul otomatis.
NEXT_PUBLIC_SUPPORT_WHATSAPP=628xxxxxxxxxx

# KetantechPay gateway
KETANTECHPAY_BASE_URL=https://pay.ketantech.my.id
KETANTECHPAY_CLIENT_KEY=isi_client_key_dari_dashboard

# Order behavior
ORDER_EXPIRE_MINUTES=15
ORDER_DATA_FILE=./data/orders.json

# Voucher packages JSON. Profile harus sama dengan profile MikroTik/bot voucher.
VOUCHER_PACKAGES_JSON=[{"id":"1-jam","profile":"1 Jam","name":"1 Jam","price":2000,"description":"Internet WiFi 1 jam","enabled":true},{"id":"2-jam","profile":"2 Jam","name":"2 Jam","price":3000,"description":"Internet WiFi 2 jam","enabled":true},{"id":"1-hari","profile":"1 Hari","name":"1 Hari","price":5000,"description":"Internet WiFi 1 hari","enabled":true}]

# Internal voucher generator. Untuk production, arahkan ke local API bot MikroTik.
# POST JSON: { orderId, profile, customerName, customerPhone, source }
# Response JSON: { ok: true, voucherCode: "123456" }
BOT_INTERNAL_GENERATE_URL=http://127.0.0.1:8082/internal/generate-voucher
BOT_INTERNAL_TOKEN=isi_token_internal

# Development only: kalau true, generate voucher dummy tanpa panggil bot.
WIFI_VOUCHER_MOCK_GENERATE=false
